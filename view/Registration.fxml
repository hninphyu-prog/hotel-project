<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" fx:id="edi" prefHeight="780.0" prefWidth="854.0" style="-fx-background-color: #d4f0df;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegistrationController">
   <children>
      <Label layoutX="267.0" text="Employee Registration Form">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="18.0" layoutY="298.0" text="Name" />
      <TextField fx:id="txtName" layoutX="113.0" layoutY="294.0" onAction="#txtNameAction" prefHeight="40.0" prefWidth="278.0" />
      <Label layoutX="21.0" layoutY="374.0" text="NRC" />
      <Label layoutX="5.0" layoutY="495.0" text="Date Of Birth" />
