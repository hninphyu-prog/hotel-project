<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="1150.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RoomBookingController">
   <children>
      <Pagination fx:id="pagination" layoutX="24.0" layoutY="82.0" pageCount="20" prefHeight="480.0" prefWidth="649.0" />
      <AnchorPane layoutX="686.0" layoutY="45.0" prefHeight="546.0" prefWidth="453.0" style="-fx-background-color: white;" styleClass="shadow-pane" stylesheets="@../css/style.css">
         <children>
            <TableView fx:id="tbRoomCart" layoutX="14.0" layoutY="36.0" prefHeight="357.0" prefWidth="425.0">
               <columns>
                  <TableColumn fx:id="colRoomNo" minWidth="0.0" prefWidth="41.0" text="R.No" />
                  <TableColumn fx:id="colRoomType" prefWidth="74.0" text="Room Type" />
                  <TableColumn fx:id="colStartDate" minWidth="0.0" prefWidth="86.0" text="Check In Date" />
                  <TableColumn fx:id="colEndDate" prefWidth="97.0" text="Check Out Date" />
                  <TableColumn fx:id="colPrice" prefWidth="68.0" text="Price" />
               </columns>
            </TableView>
            <Button fx:id="btnConfirmBooking" layoutX="323.0" layoutY="486.0" mnemonicParsing="false" onAction="#handleConfirmAction" prefHeight="16.0" prefWidth="75.0" styleClass="book-button" stylesheets="@../css/style.css" text="Confirm" />
            <Label layoutX="148.0" layoutY="428.0" text="Total Charges" />
            <TextField fx:id="txtTotal" layoutX="288.0" layoutY="423.0" />
            <Label fx:id="lblDeposit_rate" layoutX="147.0" layoutY="461.0" text="Deposit (30%)" />
            <TextField fx:id="txtDeposit" layoutX="288.0" layoutY="456.0" />
            <Button fx:id="btnCancelBooking" layoutX="183.0" layoutY="486.0" mnemonicParsing="false" onAction="#handleCancelBookingAction" prefHeight="30.0" prefWidth="64.0" styleClass="cancel-button" stylesheets="@../css/style.css" text="Cancel" />
         </children>
      </AnchorPane>
      <AnchorPane layoutX="25.0" layoutY="5.0" prefHeight="63.0" prefWidth="1101.0" styleClass="menu" stylesheets="@../css/style.css">
         <children>
            <Label layoutX="808.0" layoutY="30.0" text="Today Date" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="14.0" />
               </font>
            </Label>
            <TextField fx:id="txtTodayDate" layoutX="901.0" layoutY="25.0" />
            <DatePicker fx:id="start_date_dp" layoutX="22.0" layoutY="25.0" onAction="#handle_start_date_action" promptText="Check_in Date" />
            <DatePicker fx:id="end_date_dp" layoutX="212.0" layoutY="26.0" onAction="#handle_end_date_action" promptText="Check_out Date" />
            <ComboBox fx:id="roomType_cb_box" layoutX="398.0" layoutY="23.0" onAction="#handle_room_type_action" prefHeight="25.0" prefWidth="174.0" promptText="Room Type" />
            <Button fx:id="btn_refresh" layoutX="588.0" layoutY="22.0" mnemonicParsing="false" onAction="#handleRefreshAction" prefHeight="29.0" prefWidth="90.0" styleClass="white-button" stylesheets="@../css/style.css" text="Refresh" />
            <Label layoutX="458.0" layoutY="3.0" text="Room Type" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="14.0" />
               </font>
            </Label>
            <Label layoutX="31.0" layoutY="3.0" text="Check In Date" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="14.0" />
               </font>
            </Label>
            <Label layoutX="218.0" layoutY="6.0" text="Check Out Date" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="14.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
