<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="436.0" prefWidth="468.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.Update_PasswordController">
   <children>
      <Label layoutX="72.0" layoutY="10.0" text="Update Your Password">
         <font>
            <Font name="System Bold" size="30.0" />
         </font>
      </Label>
      <Label layoutX="43.0" layoutY="135.0" text="Current Password">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Label layoutX="42.0" layoutY="208.0" text="New Password">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Button fx:id="btnCancle" layoutX="266.0" layoutY="373.0" mnemonicParsing="false" onAction="#handlebtnCanAction" styleClass="cancel-button" stylesheets="@../css/style.css" text="Cancle" />
      <Button fx:id="btnConfirm" layoutX="347.0" layoutY="373.0" mnemonicParsing="false" onAction="#handlebtnConfirmAction" style="-fx-background-color: green;" styleClass="book-button" stylesheets="@../css/style.css" text="Confirm" />
      <Label layoutX="43.0" layoutY="278.0" text="Confirm New Password">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <PasswordField fx:id="txtcurrentpasswotd" layoutX="41.0" layoutY="163.0" prefHeight="31.0" prefWidth="370.0" />
      <PasswordField fx:id="txtconfirmnewpassword" layoutX="43.0" layoutY="305.0" prefHeight="31.0" prefWidth="370.0" />
      <PasswordField fx:id="txtnewpassword" layoutX="42.0" layoutY="239.0" prefHeight="31.0" prefWidth="370.0" />
   </children>
</AnchorPane>
