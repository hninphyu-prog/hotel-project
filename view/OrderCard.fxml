      <Button fx:id="btnUpdate" layoutX="224.0" layoutY="138.0" mnemonicParsing="false" onAction="#handleUpdateAction" text="Update" />
      <Label layoutX="36.0" layoutY="67.0" text="Current Status" />
      <Label layoutX="46.0" layoutY="108.0" text="New Status" />
      <TextField fx:id="txtCurrentStatus" layoutX="130.0" layoutY="62.0" />
      <TextField fx:id="txtNewStatus" layoutX="130.0" layoutY="103.0" />
      <Button fx:id="btnCancel" layoutX="128.0" layoutY="138.0" mnemonicParsing="false" onAction="#handleCancelAction" text="Cancel" />
   </children>
</AnchorPane>
