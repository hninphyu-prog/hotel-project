          <ColumnConstraints hgrow="SOMETIMES" maxWidth="182.0" minWidth="10.0" prefWidth="143.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints maxHeight="71.0" minHeight="10.0" prefHeight="55.0" vgrow="SOMETIMES" />
          <RowConstraints maxHeight="82.0" minHeight="10.0" prefHeight="55.0" vgrow="SOMETIMES" />
          <RowConstraints maxHeight="77.0" minHeight="10.0" prefHeight="55.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label styleClass="text-color" stylesheets="@../css/style.css" text="Cloth Id" textFill="WHITE">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <Label styleClass="text-color" stylesheets="@../css/style.css" text="Cloth Name" textFill="WHITE" GridPane.rowIndex="1">
