      <Label layoutX="20.0" layoutY="449.0" text="Gender" />
      <TextField fx:id="txtPhone" layoutX="120.0" layoutY="564.0" onAction="#PhoneAction" prefHeight="40.0" prefWidth="271.0" />
      <RadioButton fx:id="rdMale" layoutX="117.0" layoutY="451.0" mnemonicParsing="false" onAction="#rbmaleAction" text="Male">
         <toggleGroup>
            <ToggleGroup fx:id="tgGender" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="rdFemale" layoutX="236.0" layoutY="452.0" mnemonicParsing="false" onAction="#rbFemaleAction" text="Female" toggleGroup="$tgGender" />
      <Label layoutX="30.0" layoutY="637.0" text="Email" />
      <TextField fx:id="txtEmail" layoutX="118.0" layoutY="628.0" onAction="#emailAction" prefHeight="40.0" prefWidth="271.0" />
      <Label layoutX="427.0" layoutY="306.0" text="Position" />
      <Label fx:id="lblemail" textFill="red" visible="false" />

