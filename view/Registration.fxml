      <DatePicker fx:id="txtHire" layoutX="565.0" layoutY="441.0" onAction="#hireAction" prefHeight="40.0" prefWidth="236.0" promptText="type hire date" />
      <Label layoutX="425.0" layoutY="495.0" text="Salary" />
      <TextField fx:id="txtSalary" layoutX="564.0" layoutY="492.0" onAction="#salaryAction" prefHeight="35.0" prefWidth="236.0" />
      <Label layoutX="427.0" layoutY="573.0" text="Address" />
