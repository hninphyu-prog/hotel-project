      <Button fx:id="BtnClear" layoutX="617.0" layoutY="714.0" mnemonicParsing="false" onAction="#clearAction" styleClass="cancel-button" stylesheets="@../css/style.css" text="Clear Form" />
      <Button fx:id="btnSummit" layoutX="703.0" layoutY="713.0" mnemonicParsing="false" onAction="#summitAction" styleClass="book-button" stylesheets="@../css/style.css" text="Summit" />
      <Label fx:id="lblemail" layoutX="118.0" layoutY="705.0" prefHeight="21.0" prefWidth="207.0" textFill="#eb243e" />
      <Label fx:id="lblnrc" layoutX="108.0" layoutY="442.0" prefHeight="21.0" prefWidth="207.0" textFill="#eb243e" />
      <Label fx:id="lblsalary" layoutX="610.0" layoutY="569.0" prefHeight="21.0" prefWidth="184.0" textFill="#eb243e" />
      <Label fx:id="lblname" layoutX="112.0" layoutY="332.0" prefHeight="21.0" prefWidth="253.0" textFill="#eb243e" />
