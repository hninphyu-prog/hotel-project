      <Label fx:id="lblgenderAlert" layoutX="222.0" layoutY="154.0" text="please choose gender" textFill="YELLOW" visible="false" />
      <Label fx:id="lblImageAlert" layoutX="226.0" layoutY="331.0" text="please upload image" textFill="YELLOW" visible="false" />
