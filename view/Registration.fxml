         <children>
            <ImageView fx:id="imgUpload" fitHeight="200.0" fitWidth="200.0" layoutX="17.0" layoutY="7.0" pickOnBounds="true" preserveRatio="true" styleClass="image-view-with-radius">
               <image>
                  <Image url="@../Image/upload2.png" />
               </image>
            </ImageView>
         </children>
      </AnchorPane>
      <Label fx:id="lbladdress" layoutX="604.0" layoutY="674.0" prefHeight="21.0" prefWidth="223.0" textFill="#eb243e" />
      <Label fx:id="lblphone" layoutX="121.0" layoutY="639.0" prefHeight="21.0" prefWidth="216.0" textFill="#eb243e" />
      <Label layoutX="425.0" layoutY="374.0" text="Department_ID" />
      <ComboBox fx:id="comdepid" layoutX="564.0" layoutY="363.0" onAction="#handlecomdepidAction" prefHeight="40.0" prefWidth="236.0" promptText="Select" stylesheets="@../css/style.css" />
      <Button fx:id="btnback" layoutX="566.0" layoutY="714.0" mnemonicParsing="false" onAction="#handlebackAction" styleClass="refresh-admin-button" stylesheets="@../css/style.css" text="Back" />
      <Button fx:id="btnUpload" layoutX="400.0" layoutY="260.0" mnemonicParsing="false" onAction="#handleUploadAction" styleClass="button-food-type" stylesheets="@../css/style.css" text="Upload" />
   </children>
</AnchorPane>
