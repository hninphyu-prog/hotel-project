      <ComboBox fx:id="txtState" layoutX="111.0" layoutY="348.0" onAction="#StateAction" prefHeight="40.0" prefWidth="87.0" promptText="State" stylesheets="@../css/style.css" />
      <ComboBox fx:id="txtTownShip" layoutX="198.0" layoutY="348.0" onAction="#townshipAction" prefHeight="40.0" prefWidth="92.0" promptText="Town" stylesheets="@../css/style.css" />
      <ComboBox fx:id="txtNation" layoutX="291.0" layoutY="348.0" onAction="#nationActiom" prefHeight="40.0" prefWidth="101.0" promptText="Nation" stylesheets="@../css/style.css" />
