<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="1104.0" style="-fx-background-color: #F8F8F8;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FoodOrderController">
   <children>
      <TableView fx:id="tbCart" layoutX="642.0" layoutY="80.0" prefHeight="323.0" prefWidth="453.0" style="-fx-background-color: white;">
        <columns>
          <TableColumn fx:id="colNo" prefWidth="41.0" text="No." />
          <TableColumn fx:id="colItem" prefWidth="106.0" text="Item" />
            <TableColumn fx:id="colPrice" prefWidth="75.0" text="Price" />
            <TableColumn fx:id="colQty" prefWidth="83.0" text="QTY" />
            <TableColumn fx:id="colAmount" prefWidth="81.0" text="Amount" />
            <TableColumn fx:id="colAction" prefWidth="66.0" text="Action" />
        </columns>
      </TableView>
      <AnchorPane layoutX="15.0" layoutY="11.0" prefHeight="50.0" prefWidth="1081.0" styleClass="menu" stylesheets="@../css/style.css">
         <children>
            <ComboBox fx:id="comboMeal" layoutX="10.0" layoutY="11.0" prefHeight="31.0" prefWidth="187.0" promptText="Food Category" styleClass="combo-box" stylesheets="@../css/style.css" />
            <Button layoutX="949.0" layoutY="11.0" mnemonicParsing="false" onAction="#handleOrderList" prefHeight="31.0" prefWidth="104.0" styleClass="white-button" stylesheets="@../css/style.css" text="Order List" />
            <Button layoutX="219.0" layoutY="14.0" mnemonicParsing="false" onAction="#handleRefreshAction" styleClass="refresh-button" stylesheets="@../css/style.css" text="Refresh" />
         </children>
      </AnchorPane>
      <AnchorPane layoutX="642.0" layoutY="418.0" prefHeight="174.0" prefWidth="453.0" style="-fx-background-color: white;">
         <children>
            <Label layoutX="24.0" layoutY="56.0" text="Room No" />
            <TextField fx:id="txtTotal" layoutX="114.0" layoutY="92.0" prefHeight="31.0" prefWidth="157.0" styleClass="purple-text-field" stylesheets="@../css/style.css" />
            <Label layoutX="24.0" layoutY="104.0" text="Total" />
            <Button fx:id="btnConfirm" layoutX="186.0" layoutY="133.0" mnemonicParsing="false" onAction="#handleConfirmAction" prefHeight="17.0" prefWidth="79.0" styleClass="button-royal" stylesheets="@../css/style.css" text="Confirm" />
            <Button fx:id="btnEnter" layoutX="113.0" layoutY="40.0" mnemonicParsing="false" onAction="#handleEnterAction" prefHeight="40.0" prefWidth="157.0" styleClass="button-royal" stylesheets="@../css/style.css" text="Enter  Room No" />
         </children>
      </AnchorPane>
      <Pagination fx:id="paginationFood" layoutX="15.0" layoutY="150.0" prefHeight="442.0" prefWidth="603.0" style="-fx-background-color: white;" />
      <HBox fx:id="btn_container" layoutX="15.0" layoutY="92.0" prefHeight="56.0" prefWidth="603.0" stylesheets="@../css/style.css" />
      <Label layoutX="26.0" layoutY="69.0" text="Cuisine" underline="true">
         <font>
            <Font size="14.0" />
         </font></Label>
   </children>
</AnchorPane>
