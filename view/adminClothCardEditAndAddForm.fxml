      </Label>
      <Button fx:id="btnUploadImage" layoutX="235.0" layoutY="343.0" mnemonicParsing="false" onAction="#handleUploadImageAction" text="Upload Image" />
      <AnchorPane layoutY="385.0" prefHeight="42.0" prefWidth="450.0" style="-fx-background-color: #FDF5E6;" stylesheets="@../css/style.css" AnchorPane.bottomAnchor="-5.0">
         <children>
            <Button fx:id="btnCancel" layoutX="126.0" layoutY="6.0" mnemonicParsing="false" onAction="#handleCancelAction" styleClass="cancel-button" stylesheets="@../css/style.css" text="Cancel" />
            <Button fx:id="btnUpdate" layoutX="267.0" layoutY="4.0" mnemonicParsing="false" onAction="#handleUpdateAction" prefWidth="69.0" styleClass="book-button" stylesheets="@../css/style.css" text="Update" />
            <Button fx:id="btnAdd" layoutX="267.0" layoutY="4.0" mnemonicParsing="false" onAction="#handleAddAction" prefWidth="69.0" styleClass="button-royal" stylesheets="@../css/style.css" text="Add" />
