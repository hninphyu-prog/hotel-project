<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="1041.0" style="-fx-background-color: pink;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminLaundaryController">
   <children>
      <AnchorPane prefHeight="600.0" prefWidth="554.0" style="-fx-background-color: #d4f0df;">
         <children>
            <TextField fx:id="txtsearchclothbar" layoutX="73.0" layoutY="26.0" onAction="#handleSearchClothBarAction" promptText="search cloth name" styleClass="admin-text-field" stylesheets="@../css/style.css" />
            <Label layoutX="35.0" layoutY="61.0" styleClass="text-color" stylesheets="@../css/style.css" text="Gender" textFill="WHITE" />
            <Button fx:id="btnClothRefresh" layoutX="231.0" layoutY="26.0" mnemonicParsing="false" onAction="#handleClothRefreshAction" styleClass="refresh-admin-button" stylesheets="@../css/style.css" text="Refresh" />
            <Button fx:id="btnaddCloth" layoutX="313.0" layoutY="26.0" mnemonicParsing="false" onAction="#handleAddClothAction" styleClass="button-food-type" stylesheets="@../css/style.css" text="Add New Cloth" />
            <Pagination fx:id="pagination" layoutX="2.0" layoutY="98.0" prefHeight="475.0" prefWidth="545.0" />
            <HBox fx:id="genderHbox" layoutX="98.0" layoutY="56.0" prefHeight="35.0" prefWidth="320.0" />
         </children>
      </AnchorPane>
      <AnchorPane layoutX="554.0" prefHeight="600.0" prefWidth="518.0" style="-fx-background-color: #F5F5DC;" styleClass="admin-food-card" stylesheets="@../css/style.css">
         <children>
            <TableView fx:id="tbServiceView" layoutX="13.0" layoutY="106.0" prefHeight="440.0" prefWidth="493.0">
              <columns>
                <TableColumn fx:id="colService_id" prefWidth="24.0" text="ID" />
                <TableColumn fx:id="col_serviceType" prefWidth="91.0" text="Service Type" />
                  <TableColumn fx:id="col_clothName" prefWidth="94.0" text="Cloth Name" />
                  <TableColumn fx:id="colGender" minWidth="0.0" prefWidth="82.0" text="Gender" />
                  <TableColumn fx:id="colPrice" prefWidth="76.0" text="Price" />
                  <TableColumn fx:id="colAction" prefWidth="52.0" text="Action" />
                  <TableColumn fx:id="colStatus" prefWidth="74.0" text="Status" />
              </columns>
            </TableView>
            <Button fx:id="btnServiceRefresh" layoutX="480.0" layoutY="76.0" mnemonicParsing="false" onAction="#handleServiceRefreshAction" styleClass="refresh-admin-button" stylesheets="@../css/style.css">
               <graphic>
                  <FontAwesomeIcon glyphName="REFRESH" />
               </graphic>
            </Button>
            <ComboBox fx:id="combo_serviceType" layoutX="12.0" layoutY="75.0" onAction="#handleserviceTypeComboAction" prefWidth="150.0" />
            <ComboBox fx:id="combo_serviceStatus" layoutX="326.0" layoutY="75.0" onAction="#handle_statusComboAction" prefWidth="150.0" />
            <Label layoutX="48.0" layoutY="54.0" text="service type" />
            <Label layoutX="348.0" layoutY="54.0" text="service status" />
            <TextField fx:id="txtSearchServiceBar" layoutX="171.0" layoutY="74.0" onAction="#handleSearchServiceBarAction" promptText="search cloth name" styleClass="admin-text-field" stylesheets="@../css/style.css" />
            <Button fx:id="btnAddNewServiceType" layoutX="348.0" layoutY="552.0" mnemonicParsing="false" onAction="#handleAddNewServiceTypeAction" prefHeight="27.0" prefWidth="149.0" styleClass="refresh-admin-button" stylesheets="@../css/style.css" text="Add new Service Type" />
         </children></AnchorPane>
   </children>
</AnchorPane>
