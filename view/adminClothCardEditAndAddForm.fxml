<AnchorPane id="AnchorPane" prefHeight="422.0" prefWidth="450.0" style="-fx-background-color: #FDF5E6;" styleClass="rounded-image-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminClothCardEditAndAddFormController">
   <children>
      <GridPane layoutX="39.0" layoutY="14.0" prefHeight="150.0" prefWidth="144.0">
